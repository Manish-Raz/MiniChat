<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <h3>All Chats</h3>
    <form method="GET" action="/chats/new">
        <button class="btn-new">Add New Chat</button>
    </form>
    <br><br>


   <% for(let chat of chats){ %>
        <div class="chat">
            <p><span class="from">From:</span> <%= chat.from %></p>
            <div class="message">
                <p><span class="green">message:</span> <%= chat.msg %></p>
                <form  method="GET" action="/chats/<%= chat._id %>/edit">
                    <button class="edit">Edit</button>
                </form>
            </div>
            <p><span class="to">To:</span> <%=chat.to %></p>
            <hr>
            <p><%= chat.created_at.toString().split(" ")[4] %></p>
            <p><%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %></p>
             <form method="POST" action="/chats/<%= chat._id %>?_method=DELETE">
                <button class="del">Delete</button>
             </form>
        </div>
 <%   } %>
    
</body>
</html>